---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import StatsGrid from "@/components/StatsGrid.astro";
import StatItem from "@/components/StatItem.astro";
import DetailSection from "@/components/DetailSection.astro";
import EmptyState from "@/components/EmptyState.astro";
import PaymentBadge from "@/components/PaymentBadge.astro";
import BudgetHeroCard from "@/components/BudgetHeroCard.astro";
import {
	getLangFromUrl,
	useTranslations,
	getLocalizedPath,
	formatCurrency,
	formatDateFull,
} from "@/i18n/utils";
import { getBudgetWithDetails } from "@/lib/data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pb = Astro.locals.pb;
const { id } = Astro.params;

// Get year from URL or use current year
const url = new URL(Astro.request.url);
const currentYear = new Date().getFullYear();
const selectedYear = parseInt(
	url.searchParams.get("year") || String(currentYear),
);

const data = await getBudgetWithDetails(pb, id!, selectedYear);
const budget = data?.budget ?? null;
const budgetItem = data?.budgetItem ?? null;
const obligations = data?.obligations ?? [];
const payments = data?.payments ?? [];
const transfers = data?.transfers ?? [];

// Calculate totals
const totalObligatedCash = obligations.reduce(
	(sum, o) => sum + (o.cash || 0),
	0,
);
const totalObligatedCost = obligations.reduce(
	(sum, o) => sum + (o.cost || 0),
	0,
);
// Only count payments with status "paid" as spent
const totalPaid = payments
	.filter((p) => p.status === "paid")
	.reduce((sum, p) => sum + (p.amount || 0), 0);

// Calculate transfers in/out
const transfersIn = transfers
	.filter((t) => t.to === id)
	.reduce((sum, t) => sum + (t.cash || 0), 0);
// All outgoing transfers (both to other budgets and to undefined = system exits)
const transfersOut = transfers
	.filter((t) => t.from === id)
	.reduce((sum, t) => sum + (t.cash || 0), 0);

const transfersInCost = transfers
	.filter((t) => t.to === id)
	.reduce((sum, t) => sum + (t.cost || 0), 0);
const transfersOutCost = transfers
	.filter((t) => t.from === id)
	.reduce((sum, t) => sum + (t.cost || 0), 0);

// Transfers in with no `from` = incoming from outside the system
const transfersInNoFrom = transfers
	.filter((t) => t.to === id && !t.from)
	.reduce((sum, t) => sum + (t.cash || 0), 0);
const transfersInNoFromCost = transfers
	.filter((t) => t.to === id && !t.from)
	.reduce((sum, t) => sum + (t.cost || 0), 0);

// Transfers out with no `to` = cash leaving the system entirely
const transfersOutNoTo = transfers
	.filter((t) => t.from === id && !t.to)
	.reduce((sum, t) => sum + (t.cash || 0), 0);

// Adjusted cash = original + transfers in − transfers out
const adjustedCash = (budgetItem?.cash || 0) + transfersIn - transfersOut;
// Adjusted cost = original + transfers in − transfers out
const adjustedCost = (budgetItem?.cost || 0) + transfersInCost - transfersOutCost;

// Combined hero totals
const heroTotal = adjustedCash + adjustedCost;
const heroTotalObligated = totalObligatedCash + totalObligatedCost;
// Total Remaining = Total − Total Obligated − transfers out of system − paid
const heroRemaining = heroTotal - heroTotalObligated - transfersOutNoTo - totalPaid;

// True remaining: adjusted cash − paid (actual cash balance)
const remainingCash = adjustedCash - totalPaid;
// Uncommitted: adjusted − obligated (commitment reference)
const uncommittedCash = adjustedCash - totalObligatedCash;
const remainingCost = (budgetItem?.cost || 0) + transfersInNoFromCost - totalObligatedCost;

const backPath = getLocalizedPath("/budget", lang);
---

<Layout>
	{
		!budget ? (
			<div class="py-20 text-center">
				<p class="text-muted-foreground text-lg">
					{t("detail.budgetItemNotFound")}
				</p>
				<a
					href={backPath}
					class="text-base text-muted-foreground hover:text-foreground mt-4 inline-block"
				>
					← {t("detail.backToBudget")}
				</a>
			</div>
		) : (
			<div class="space-y-10 md:space-y-20">
				{/* Header */}
				<PageHeader
					title={budget.name}
					subtitle={budget.ref}
					backHref={backPath}
					backLabel={t("detail.backToBudget")}
				>
					<div class="flex items-center gap-4 mt-4">
						<span class="badge badge-info">{selectedYear}</span>
						{budget.description && (
							<span class="text-muted-foreground">
								{budget.description}
							</span>
						)}
					</div>
				</PageHeader>

				{/* Budget Allocation + Cash Balance */}
				<DetailSection title={t("budget.items")}>
					{!budgetItem ? (
						<EmptyState
							message={`${t("budget.noItemsFound")} ${selectedYear}`}
						/>
					) : (
						<BudgetHeroCard
							total={heroTotal}
							obligated={heroTotalObligated}
							remaining={heroRemaining}
							spent={totalPaid}
							transfersOut={transfersOutNoTo}
							lang={lang}
						/>
					)}
				</DetailSection>

				{/* Financial Summary */}
				<DetailSection title={t("detail.financials")}>
					<StatsGrid columns={4}>
						<StatItem
							label={t("budget.obligatedCash")}
							value={formatCurrency(totalObligatedCash, lang)}
							size="md"
							mono
						/>
						<StatItem
							label={t("budget.obligatedCost")}
							value={formatCurrency(totalObligatedCost, lang)}
							size="md"
							variant="muted"
							mono
						/>
						<StatItem
							label={t("common.paid")}
							value={formatCurrency(totalPaid, lang)}
							size="md"
							variant="positive"
							mono
						/>
						<StatItem
							label={t("budget.payments")}
							value={String(payments.length)}
							size="md"
							variant="muted"
						/>
					</StatsGrid>
				</DetailSection>

				{/* Obligations */}
				<DetailSection
					title={`${t("budget.obligations")} (${selectedYear})`}
				>
					{obligations.length === 0 ? (
						<EmptyState message={t("detail.noObligations")} />
					) : (
						<div class="table-scroll">
							<table class="data-table min-w-full">
								<thead>
									<tr>
										<th>{t("table.project")}</th>
										<th class="hidden sm:table-cell">{t("table.ref")}</th>
										<th class="hidden md:table-cell">{t("table.date")}</th>
										<th class="text-right">
											{t("budget.cash")}
										</th>
										<th class="hidden sm:table-cell text-right">
											{t("budget.cost")}
										</th>
									</tr>
								</thead>
								<tbody>
									{obligations.map((obligation) => (
										<tr>
											<td class="align-middle">
												<p class="font-medium">{obligation.expand?.project?.name || "—"}</p>
												<p class="sm:hidden text-xs text-muted-foreground mono mt-0.5">{obligation.ref}</p>
												<p class="md:hidden text-xs text-muted-foreground mt-0.5">{formatDateFull(obligation.date || obligation.created, lang)}</p>
											</td>
											<td class="hidden sm:table-cell mono text-muted-foreground align-middle">
												{obligation.ref}
											</td>
											<td class="hidden md:table-cell text-muted-foreground align-middle">
												{formatDateFull(
													obligation.date ||
														obligation.created,
													lang,
												)}
											</td>
											<td class="text-right font-medium arshid align-middle whitespace-nowrap">
												{formatCurrency(
													obligation.cash || 0,
													lang,
												)}
											</td>
											<td class="hidden sm:table-cell text-right text-muted-foreground arshid align-middle whitespace-nowrap">
												{formatCurrency(
													obligation.cost || 0,
													lang,
												)}
											</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					)}
				</DetailSection>

				{/* Payments */}
				<DetailSection
					title={`${t("budget.payments")} (${selectedYear})`}
				>
					{payments.length === 0 ? (
						<EmptyState message={t("detail.noPayments")} />
					) : (
						<div class="table-scroll">
							<table class="data-table min-w-full">
								<thead>
									<tr>
										<th>{t("payments.payment")}</th>
										<th class="hidden sm:table-cell">{t("table.ref")}</th>
										<th>{t("table.status")}</th>
										<th class="hidden md:table-cell">{t("table.date")}</th>
										<th class="text-right">
											{t("table.amount")}
										</th>
									</tr>
								</thead>
								<tbody>
									{payments.map((payment) => (
										<tr>
											<td class="align-middle">
												<p class="font-medium">
													{payment.name ||
														payment.expand?.project?.name ||
														"—"}
												</p>
												<p class="sm:hidden text-xs text-muted-foreground arshid mt-0.5">{payment.ref}</p>
												<p class="md:hidden text-xs text-muted-foreground mt-0.5">{formatDateFull(payment.created, lang)}</p>
											</td>
											<td class="hidden sm:table-cell arshid text-muted-foreground align-middle">
												{payment.ref}
											</td>
											<td class="align-middle">
												<PaymentBadge status={payment.status} lang={lang} />
											</td>
											<td class="hidden md:table-cell text-muted-foreground align-middle">
												{formatDateFull(
													payment.created,
													lang,
												)}
											</td>
											<td class="text-right font-medium arshid align-middle whitespace-nowrap">
												{formatCurrency(
													payment.amount || 0,
													lang,
												)}
											</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					)}
				</DetailSection>

				{/* Transfers */}
				<DetailSection
					title={`${t("detail.transfers")} (${selectedYear})`}
				>
					{transfers.length === 0 ? (
						<EmptyState message={t("detail.noTransfers")} />
					) : (
						<div class="table-scroll">
							<table class="data-table min-w-full">
								<thead>
									<tr>
										<th>{t("common.from")}</th>
										<th>{t("common.to")}</th>
										<th class="hidden md:table-cell">{t("table.date")}</th>
										<th class="hidden lg:table-cell">{t("common.note")}</th>
										<th class="text-right">
											{t("budget.cash")}
										</th>
									</tr>
								</thead>
								<tbody>
									{transfers.map((transfer) => {
										const isIncoming = transfer.to === id;
										return (
											<tr>
												<td class="align-middle">
													{transfer.from === id ? (
														<span class="font-medium">
															{budget?.name}
														</span>
													) : (
														<span class="text-muted-foreground">
															{transfer.expand?.from
																?.name ||
																transfer.from}
														</span>
													)}
													<p class="md:hidden text-xs text-muted-foreground mt-0.5">{formatDateFull(transfer.created, lang)}</p>
												</td>
												<td class="align-middle">
													{transfer.to === id ? (
														<span class="font-medium">
															{budget?.name}
														</span>
													) : (
														<span class="text-muted-foreground">
															{transfer.expand?.to
																?.name ||
																transfer.to}
														</span>
													)}
												</td>
												<td class="hidden md:table-cell text-muted-foreground align-middle">
													{formatDateFull(
														transfer.created,
														lang,
													)}
												</td>
												<td class="hidden lg:table-cell text-muted-foreground max-w-xs truncate align-middle">
													{transfer.note || "—"}
												</td>
												<td
													class:list={[
														"text-right font-medium arshid align-middle whitespace-nowrap",
														isIncoming
															? "text-emerald-600"
															: "text-destructive",
													]}
												>
													{isIncoming ? "+" : "-"}
													{formatCurrency(
														transfer.cash || 0,
														lang,
													)}
												</td>
											</tr>
										);
									})}
								</tbody>
							</table>
						</div>
					)}
				</DetailSection>
			</div>
		)
	}
</Layout>
