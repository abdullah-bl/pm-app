---
import Layout from "@/layouts/Layout.astro";
import PageHeader from "@/components/PageHeader.astro";
import StatsGrid from "@/components/StatsGrid.astro";
import StatItem from "@/components/StatItem.astro";
import EmptyState from "@/components/EmptyState.astro";
import PhaseBadge from "@/components/PhaseBadge.astro";
import {
	getLangFromUrl,
	useTranslations,
	getLocalizedPath,
	formatCurrency,
	formatDateFull,
} from "@/i18n/utils";
import { getProjects, getProjectYears } from "@/lib/data";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const pb = Astro.locals.pb;

// Get filter params from URL
const url = new URL(Astro.request.url);
const filterPhase = url.searchParams.get("phase") || "";
const filterActive = url.searchParams.get("active") || "";
const filterYear = url.searchParams.get("year") || "";

// Get all projects first (unfiltered) for year extraction
const { projects: allProjects, phases } = await getProjects(pb);

// Get unique years from all projects
const availableYears = getProjectYears(allProjects);

// Now get filtered projects
const { projects } = await getProjects(pb, {
	phase: filterPhase || undefined,
	active:
		filterActive === "true"
			? true
			: filterActive === "false"
				? false
				: null,
	year: filterYear ? parseInt(filterYear) : undefined,
});

const activeCount = projects.filter((p) => p.active).length;
const totalValue = projects.reduce((sum, p) => sum + (p.total || 0), 0);

// Get base path for filter navigation
const basePath = getLocalizedPath("/projects", lang);
---

<Layout>
	<div class="space-y-10 md:space-y-20">
		<!-- Header with Filters -->
		<PageHeader title={t("projects.title")} subtitle={t("projects.subtitle")} />

			<!-- Filters -->
			<form
				id="filters"
				class="flex flex-wrap items-center gap-3 sm:gap-6 mt-6 pt-5 border-t border-border"
			>
				<div class="flex items-center gap-3">
					<label
						for="filter-year"
						class="text-base text-muted-foreground"
					>
						{t("filter.year")}
					</label>
					<select
						id="filter-year"
						name="year"
						class="border border-border rounded-md px-3 py-2 text-base bg-background font-mono filter-select min-w-24"
					>
						<option value="">{t("filter.all")}</option>
						{
							availableYears.map((year) => (
								<option
									value={String(year)}
									selected={filterYear === String(year)}
								>
									{year}
								</option>
							))
						}
					</select>
				</div>

				<div class="flex items-center gap-3">
					<label
						for="filter-phase"
						class="text-base text-muted-foreground"
					>
						{t("filter.phase")}
					</label>
					<select
						id="filter-phase"
						name="phase"
						class="border border-border rounded-md px-3 py-2 text-base bg-background filter-select min-w-32"
					>
						<option value="">{t("filter.all")}</option>
						{
							phases.map((phase) => (
								<option
									value={phase.id}
									selected={filterPhase === phase.id}
								>
									{phase.name}
								</option>
							))
						}
					</select>
				</div>

				<div class="flex items-center gap-3">
					<label
						for="filter-status"
						class="text-base text-muted-foreground"
					>
						{t("filter.status")}
					</label>
					<select
						id="filter-status"
						name="active"
						class="border border-border rounded-md px-3 py-2 text-base bg-background filter-select min-w-28"
					>
						<option value="">{t("filter.all")}</option>
						<option value="true" selected={filterActive === "true"}>
							{t("filter.active")}
						</option>
						<option
							value="false"
							selected={filterActive === "false"}
						>
							{t("filter.inactive")}
						</option>
					</select>
				</div>

				{
					(filterPhase || filterActive || filterYear) && (
						<a
							href={basePath}
							class="text-base text-muted-foreground hover:text-foreground transition-colors ml-2"
						>
							× {t("projects.clearFilters")}
						</a>
					)
				}
			</form>

			<script define:vars={{ basePath }}>
				document
					.querySelectorAll(".filter-select")
					.forEach((select) => {
						select.addEventListener("change", () => {
							const form = document.getElementById("filters");
							const params = new URLSearchParams();
							new FormData(form).forEach((value, key) => {
								if (value) params.set(key, value.toString());
							});
							window.location.href =
								basePath +
								(params.toString()
									? "?" + params.toString()
									: "");
						});
					});
			</script>

		<!-- Stats -->
		<StatsGrid columns={3}>
			<StatItem label={t("projects.showing")} value={projects.length} />
			<StatItem label={t("projects.active")} value={activeCount} variant="positive" />
			<StatItem label={t("projects.totalValue")} value={formatCurrency(totalValue, lang)} mono />
		</StatsGrid>

		<!-- Projects List -->
		<section>
			<h2 class="section-title">{t("projects.allProjects")}</h2>

			{
				projects.length === 0 ? (
					<EmptyState message={t("projects.noProjectsFound")} />
				) : (
					<div class="table-scroll">
						<table class="data-table min-w-full">
							<thead>
								<tr>
									<th class="hidden sm:table-cell">{t("table.ref")}</th>
									<th>{t("table.project")}</th>
									<th class="text-right">{t("table.amount")}</th>
									<th class="hidden sm:table-cell">{t("table.phase")}</th>
									<th class="hidden sm:table-cell text-right">{t("table.status")}</th>
								</tr>
							</thead>
							<tbody>
								{projects.map((project) => (
									<tr
										class="clickable"
										onclick={`window.location.href='${getLocalizedPath(`/projects/${project.id}`, lang)}'`}
									>
										<td class="hidden sm:table-cell mono text-muted-foreground">
											{project.slug || project.ref}
										</td>
										<td class="align-middle">
											<p class="font-medium text-base leading-snug">
												{project.name}
											</p>
											<p class="mono text-xs text-muted-foreground mt-0.5 sm:hidden">
												{project.slug || project.ref}
											</p>
											{project.expand?.phase && (
												<span class="sm:hidden mt-1.5">
													<PhaseBadge phase={project.expand.phase} />
												</span>
											)}
										</td>
										<td class="text-right arshid align-middle whitespace-nowrap">
											{formatCurrency(
												project.total || 0,
												lang,
											)}
										</td>
										<td class="hidden sm:table-cell align-middle">
											<PhaseBadge phase={project.expand?.phase} />
										</td>
										<td class="hidden sm:table-cell text-right align-middle">
											<span
												class:list={[
													"status-dot",
													project.active
														? "status-dot-active"
														: "status-dot-inactive",
												]}
												title={
													project.active
														? t("filter.active")
														: t("filter.inactive")
												}
											/>
										</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				)
			}
		</section>
	</div>
</Layout>
