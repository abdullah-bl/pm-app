---
import { ClientRouter } from "astro:transitions";

import {
    getLangFromUrl,
    useTranslations,
    getLocalizedPath,
    getDirection,
} from "@/i18n/utils";
import LanguageSwitcher from "@/components/LanguageSwitcher.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const dir = getDirection(lang);

const currentPath = Astro.url.pathname;

const isActive = (href: string) => {
    const localizedHref = getLocalizedPath(href, lang);
    if (href === "/") {
        return currentPath === localizedHref || currentPath === `/${lang}`;
    }
    return currentPath.startsWith(localizedHref);
};

const navItems = [
    { href: "/", label: t("nav.overview") },
    { href: "/search", label: t("nav.search") },
    { href: "/chat", label: t("nav.chat") },
    { href: "/projects", label: t("nav.projects") },
    { href: "/payments", label: t("nav.payments") },
    { href: "/budget", label: t("nav.budget") },
];

const navIcons: Record<string, string> = {
    "/": `<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
    "/search": `<circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>`,
    "/projects": `<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>`,
    "/payments": `<rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/>`,
    "/budget": `<line x1="18" x2="18" y1="20" y2="10"/><line x1="12" x2="12" y1="20" y2="4"/><line x1="6" x2="6" y1="20" y2="14"/>`,
    "/chat": `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
};
---

<!-- Top Header -->
<header
    class="border-b border-border bg-background/80 backdrop-blur-md z-50 sticky top-0"
>
    <div
        class="items-center justify-between max-w-6xl mx-auto px-6 py-4 flex"
    >
        <!-- Logo -->
        <a
            href={getLocalizedPath("/", lang)}
            class="text-[11px] font-bold tracking-[0.15em] uppercase text-foreground shrink-0"
        >
            PM / {new Date().getFullYear()}
        </a>

        <!-- Desktop Nav (hidden on mobile) -->
        <nav class="hidden sm:flex items-center gap-8">
            {
                navItems.map((item) => (
                    <a
                        href={getLocalizedPath(item.href, lang)}
                        class:list={[
                            "text-sm transition-colors",
                            isActive(item.href)
                                ? "text-foreground font-medium"
                                : "text-muted-foreground hover:text-foreground",
                        ]}
                    >
                        {item.label}
                    </a>
                ))
            }
        </nav>

        <!-- Actions -->
        <div class="flex items-center gap-4">
            <LanguageSwitcher />
            <button
                id="sign-out-btn"
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
                {t("auth.logout")}
            </button>
        </div>
    </div>
</header>

<!-- Mobile Bottom Nav (hidden on sm+) -->
<nav
    class="sm:hidden fixed bottom-0 inset-x-0 z-50 bg-background/95 backdrop-blur-md border-t border-border"
    style="padding-bottom: env(safe-area-inset-bottom)"
>
    <div class="grid grid-cols-5">
        {
            navItems
                .filter((item) => item.href !== "/chat")
                .map((item) => {
                    const active = isActive(item.href);
                    return (
                        <a
                            href={getLocalizedPath(item.href, lang)}
                            class:list={[
                                "flex flex-col items-center gap-1 py-2.5 px-1 transition-colors",
                                active
                                    ? "text-foreground"
                                    : "text-muted-foreground",
                            ]}
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                set:html={navIcons[item.href]}
                            />
                            <span class="text-[10px] font-medium leading-tight">
                                {item.label}
                            </span>
                        </a>
                    );
                })
        }
    </div>
</nav>

<ClientRouter />

<script>
    document.addEventListener("astro:page-load", () => {
        document
            .getElementById("sign-out-btn")
            ?.addEventListener("click", async () => {
                try {
                    const response = await fetch("/api/logout", {
                        method: "POST",
                    });

                    if (response.ok) {
                        window.location.href = "/login";
                    }
                } catch (error) {
                    console.error("Logout failed:", error);
                }
            });
    });
</script>
